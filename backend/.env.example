# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bloom_english
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bloom_english_test
DEFAULT_PROGRESS_USER_ID=user-tester

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment
ENVIRONMENT=development

# API
API_V1_PREFIX=/api

# Google OAuth (Student login)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Optional: multiple audiences if needed
AUTH_GOOGLE_CLIENT_IDS=your-google-web-client-id.apps.googleusercontent.com
